generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =======================================================================
// ENUMS (CRM + MARKETING)
// =======================================================================

enum Role {
  MARKETING_ADMIN
  DIRECTOR
  MANAGER
  BROKER
  PRE_SALES
}

enum FunnelAccessLevel {
  FULL
  READONLY
}

enum PropertyStatus {
  LANCAMENTO
  EM_OBRAS
  PRONTO
}

enum ClientOverallStatus {
  ACTIVE
  WON
  LOST
}

enum TaskType {
  CALL
  EMAIL
  WHATSAPP
  VISIT
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActiveOfferStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ActiveOfferClientStatus {
  PENDING
  CONTACTED
  NO_ANSWER
  DISCARDED
}

enum QualificationStatus {
  WAITING
  IN_PRIORITY_POOL
  IN_GENERAL_POOL
  ASSIGNED
}

// =======================================================================
// MODELS UNIFICADOS (O CORAÇÃO DO SISTEMA)
// =======================================================================

model User {
  id        String   @id // Supabase Auth UUID
  name      String
  email     String   @unique
  accountId String?
  role      Role     @default(BROKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hierarquia
  supervisorId String?
  supervisor   User?   @relation("Hierarchy", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates User[]  @relation("Hierarchy")

  // CRM Relations
  clientsAsBroker    Client[]          @relation("ClientBroker")
  clientsCreatedByMe Client[]          @relation("ClientCreatedBy")
  tasks              Task[]
  notes              Note[]
  pushSubscription   PushSubscription?

  // Property Relations
  createdProperties Property[] @relation("CreatedProperties")
  updatedProperties Property[] @relation("UpdatedProperties")

  // Roulette & Access
  rouletteAssignments LeadRouletteUser[]
  funnelAccess        UserFunnelAccess[]

  // Attendance
  attendanceRecords AttendanceRecord[]

  // Active Offers
  createdOffers ActiveOffer[]       @relation("CreatedOffers")
  assignedCalls ActiveOfferClient[] @relation("AssignedCalls")

  // Lead Pool (O que causou o erro anterior)
  qualifiedLeadsForMe Client[]       @relation("QualifiedFor")
  allowedLeadPools    LeadPoolUser[]

  facebookFormMappings FacebookFormMapping[] @relation("FbDefaultBroker")

  @@map("users")
}

model Client {
  id             String   @id @default(uuid())
  fullName       String
  email          String?  @unique
  phone          String?
  facebookLeadId String?  @unique @map("facebook_lead_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  accountId      String?

  // Ownership
  createdById String
  createdBy   User   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  brokerId    String
  broker      User   @relation("ClientBroker", fields: [brokerId], references: [id], onDelete: Restrict)

  // Real Estate Logic
  propertyOfInterestId String?
  propertyOfInterest   Property?           @relation(fields: [propertyOfInterestId], references: [id], onDelete: SetNull)
  overallStatus        ClientOverallStatus @default(ACTIVE)

  // Relations
  documents          ClientDocument[]
  tags               Tag[]               @relation("ClientTags")
  tasks              Task[]
  notes              Note[]
  saleDetails        ClientWonDetails?
  activeOfferClients ActiveOfferClient[]

  // Funnel Logic
  funnelId      String
  funnel        Funnel      @relation(fields: [funnelId], references: [id])
  funnelStageId String
  funnelStage   FunnelStage @relation(fields: [funnelStageId], references: [id])

  // Lead Pool
  qualificationStatus QualificationStatus @default(WAITING)
  qualifiedForId      String?
  qualifiedFor        User?               @relation("QualifiedFor", fields: [qualifiedForId], references: [id], onDelete: SetNull)
  enteredLeadPoolAt   DateTime?

  @@map("clients")
}

// =======================================================================
// MARKETING MODELS (REAL ROI HUB - UNIFICAÇÃO)
// =======================================================================

model AdMetric {
  id              String    @id @default(uuid())
  ad_id           String
  ad_name         String?
  clicks          Int?
  conversions     Int?
  cost_per_result Float?
  date_start      DateTime? @db.Date
  date_stop       DateTime? @db.Date
  device          String?
  impressions     Int?
  spend           Float?
  thumbnail_url   String?
  user_id         String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("ad_metrics")
}

model ApiSetting {
  id              String   @id @default(uuid())
  setting_key     String // Onde você salvará Meta App ID, Token, etc.
  encrypted_value String
  user_id         String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("api_settings")
}

model CampaignMetric {
  id            String   @id @default(uuid())
  campaign_name String
  campaign_id   String?
  spend         Float?
  impressions   Int?
  clicks        Int?
  leads         Int?
  date          DateTime @db.Date
  user_id       String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("campaign_metrics")
}

model FieldMapping {
  id          String   @id @default(uuid())
  source      String // ex: "meta_ads"
  fieldName   String // Nome no Meta
  mappedField String // Nome no modelo Client
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, fieldName])
  @@map("field_mappings")
}

// =======================================================================
// CRM MODELS (PROPRIEDADES, FUNIS, ROLETA, POOL)
// =======================================================================

model Property {
  id                String          @id @default(uuid())
  title             String
  type              String?
  features          String[]        @default([])
  address           String?
  price             Float?
  status            PropertyStatus  @default(LANCAMENTO)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  interestedClients Client[]
  images            PropertyImage[]
  propertyTypes     PropertyType[]

  creatorId String?
  creator   User?   @relation("CreatedProperties", fields: [creatorId], references: [id])
  updaterId String?
  updater   User?   @relation("UpdatedProperties", fields: [updaterId], references: [id])

  facebookFormMappings FacebookFormMapping[]

  @@map("properties")
}

model PropertyType {
  id           String   @id @default(uuid())
  name         String
  value        Float    @default(0)
  area         Float?
  dormitorios  Int?
  suites       Int?
  vagas        Int?
  floorPlanUrl String?
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_types")
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Funnel {
  id             String             @id @default(uuid())
  name           String             @unique
  isPreSales     Boolean            @default(false)
  isDefaultEntry Boolean            @default(false)
  stages         FunnelStage[]
  clients        Client[]
  roulettes      LeadRoulette[]
  userAccess     UserFunnelAccess[]

  facebookFormMappings FacebookFormMapping[]

  @@map("funnels")
}

model FunnelStage {
  id       String   @id @default(uuid())
  name     String
  order    Int
  color    String
  funnelId String
  funnel   Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  clients  Client[]

  facebookFormMappings FacebookFormMapping[]

  @@unique([funnelId, name])
  @@map("funnel_stages")
}

model LeadRoulette {
  id       String             @id @default(uuid())
  name     String
  isActive Boolean            @default(true)
  users    LeadRouletteUser[]
  funnelId String?
  funnel   Funnel?            @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  @@map("lead_roulettes")
}

model LeadRouletteUser {
  rouletteId String
  roulette   LeadRoulette @relation(fields: [rouletteId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([rouletteId, userId])
  @@map("roulette_users")
}

model LeadPoolUser {
  leadPoolId String
  leadPool   LeadPool @relation(fields: [leadPoolId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leadPoolId, userId])
  @@map("lead_pool_users")
}

model LeadPool {
  id       String         @id @default(cuid())
  name     String         @unique
  isActive Boolean        @default(true)
  users    LeadPoolUser[]

  @@map("lead_pools")
}

model AttendanceConfig {
  id           String             @id @default(cuid())
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Int
  schedules    Json
  isActive     Boolean            @default(true)
  records      AttendanceRecord[]

  @@map("attendance_configs")
}

model AttendanceRecord {
  id       String            @id @default(cuid())
  userId   String
  user     User              @relation(fields: [userId], references: [id])
  configId String?
  config   AttendanceConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)

  @@map("attendance_records")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  dateTime    DateTime
  isCompleted Boolean  @default(false)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TaskType
  priority    Priority

  @@map("tasks")
}

model Note {
  id       String @id @default(uuid())
  content  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique
  color   String
  clients Client[] @relation("ClientTags")

  @@map("tags")
}

model PushSubscription {
  id       String @id @default(cuid())
  endpoint String @unique
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model UserFunnelAccess {
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  funnelId    String
  funnel      Funnel            @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  accessLevel FunnelAccessLevel

  @@id([userId, funnelId])
  @@map("user_funnel_access")
}

model ActiveOffer {
  id          String              @id @default(uuid())
  name        String
  status      ActiveOfferStatus   @default(PENDING)
  createdById String
  createdBy   User                @relation("CreatedOffers", fields: [createdById], references: [id])
  clients     ActiveOfferClient[]

  @@map("active_offers")
}

model ActiveOfferClient {
  id            String      @id @default(uuid())
  activeOfferId String
  activeOffer   ActiveOffer @relation(fields: [activeOfferId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedToId  String
  assignedTo    User        @relation("AssignedCalls", fields: [assignedToId], references: [id])

  @@map("active_offer_clients")
}

model ClientWonDetails {
  id        String @id @default(uuid())
  saleValue Float
  clientId  String @unique
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_won_details")
}

model LostReason {
  id     String  @id @default(uuid())
  reason String
  active Boolean @default(true)

  @@map("lost_reasons")
}

model ClientDocument {
  id       String @id @default(uuid())
  name     String
  url      String
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

// =======================================================================
// FACEBOOK LEAD ADS INTEGRATION
// =======================================================================

model FacebookConnection {
  id              String                @id @default(uuid())
  accountId       String
  pageId          String
  pageName        String
  pageAccessToken String
  userAccessToken String?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  formMappings    FacebookFormMapping[]

  @@unique([accountId, pageId])
  @@map("facebook_connections")
}

model FacebookFormMapping {
  id              String             @id @default(uuid())
  connectionId    String
  connection      FacebookConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  formId          String             @unique
  formName        String
  pageId          String
  propertyId      String?
  property        Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  roletaId        String?
  funnelId        String?
  funnel          Funnel?            @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  funnelStageId   String?
  funnelStage     FunnelStage?       @relation(fields: [funnelStageId], references: [id], onDelete: SetNull)
  agencia         String?
  praca           String?
  defaultBrokerId String?
  defaultBroker   User?              @relation("FbDefaultBroker", fields: [defaultBrokerId], references: [id], onDelete: SetNull)
  isActive        Boolean            @default(true)
  lastSyncedAt    DateTime?
  leadCount       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("facebook_form_mappings")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---
enum Role {
  MARKETING_ADMIN
  DIRECTOR
  MANAGER
  BROKER
  PRE_SALES
}

enum FunnelAccessLevel {
  FULL
  READONLY
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  LAUNCH
}

enum ClientOverallStatus {
  ACTIVE
  WON
  LOST
}

enum TaskType {
  CALL
  EMAIL
  WHATSAPP
  VISIT
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActiveOfferStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ActiveOfferClientStatus {
  PENDING
  CONTACTED
  NO_ANSWER
  DISCARDED
}

enum QualificationStatus {
  WAITING
  IN_PRIORITY_POOL
  IN_GENERAL_POOL
  ASSIGNED
}

// --- MODELS ---

model User {
  id                  String               @id // Supabase Auth UUID
  name                String
  email               String               @unique
  accountId           String?
  role                Role                 @default(BROKER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  // Hierarchy
  supervisorId        String?
  supervisor          User?                @relation("Hierarchy", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates        User[]               @relation("Hierarchy")
  
  // CRM Relations
  clientsAsBroker     Client[]             @relation("ClientBroker")
  clientsCreatedByMe  Client[]             @relation("ClientCreatedBy")
  tasks               Task[]
  notes               Note[]
  pushSubscription    PushSubscription?
  
  // Property Relations
  createdProperties   Property[]           @relation("CreatedProperties")
  updatedProperties   Property[]           @relation("UpdatedProperties")

  // Roulette & Access
  rouletteAssignments LeadRouletteUser[]
  funnelAccess        UserFunnelAccess[]
  
  // Attendance
  attendanceRecords   AttendanceRecord[]

  // Active Offers
  createdOffers       ActiveOffer[]        @relation("CreatedOffers")
  assignedCalls       ActiveOfferClient[]  @relation("AssignedCalls")

  // Lead Pool
  qualifiedLeadsForMe Client[]             @relation("QualifiedFor")
  allowedLeadPools    LeadPoolUser[]

  @@map("users")
}

model Client {
  id                   String               @id @default(uuid())
  fullName             String
  email                String?              @unique
  phone                String?
  facebookLeadId       String?              @unique @map("facebook_lead_id")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accountId            String?

  // Ownership
  createdById          String
  createdBy            User                 @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  brokerId             String
  broker               User                 @relation("ClientBroker", fields: [brokerId], references: [id], onDelete: Restrict)
  
  // Real Estate Logic
  propertyOfInterestId String?
  propertyOfInterest   Property?            @relation(fields: [propertyOfInterestId], references: [id], onDelete: SetNull)
  overallStatus        ClientOverallStatus  @default(ACTIVE)
  
  // Relations
  documents            ClientDocument[]
  tags                 Tag[]                @relation("ClientTags")
  tasks                Task[]
  notes                Note[]
  saleDetails          ClientWonDetails?
  activeOfferClients   ActiveOfferClient[]

  // Funnel Logic
  funnelId             String
  funnel               Funnel               @relation(fields: [funnelId], references: [id])
  funnelStageId        String
  funnelStage          FunnelStage          @relation(fields: [funnelStageId], references: [id])

  // Lead Pool
  qualificationStatus  QualificationStatus  @default(WAITING)
  qualifiedForId       String?
  qualifiedFor         User?                @relation("QualifiedFor", fields: [qualifiedForId], references: [id], onDelete: SetNull)
  enteredLeadPoolAt    DateTime?

  @@map("clients")
}

model ClientDocument {
  id        String   @id @default(uuid())
  name      String
  url       String   // Supabase Storage URL
  type      String?  // pdf, jpg, png
  createdAt DateTime @default(now())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  clients   Client[] @relation("ClientTags")

  @@map("tags")
}

model Property {
  id                String          @id @default(uuid())
  title             String
  features          String[]        @default([])
  address           String?
  price             Float?
  type              String?
  status            PropertyStatus  @default(AVAILABLE)
  bedrooms          Int?
  bathrooms         Int?
  areaSqMeters      Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  interestedClients Client[]
  propertyTypes     PropertyType[]
  images            PropertyImage[]
  
  creatorId         String?
  creator           User?           @relation("CreatedProperties", fields: [creatorId], references: [id], onDelete: SetNull)
  updaterId         String?
  updater           User?           @relation("UpdatedProperties", fields: [updaterId], references: [id], onDelete: SetNull)

  @@map("properties")
}

model PropertyType {
  id            String           @id @default(uuid())
  name          String
  value         Float
  areaSqMeters  Float?
  bedrooms      Int?
  suites        Int?
  parkingSpaces Int?
  propertyId    String
  property      Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floorPlans    FloorPlanImage[]

  @@map("property_types")
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  createdAt  DateTime @default(now())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model FloorPlanImage {
  id             String       @id @default(uuid())
  url            String
  createdAt      DateTime     @default(now())
  propertyTypeId String
  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id], onDelete: Cascade)

  @@map("floor_plan_images")
}

model Note {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pending")
  dateTime    DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TaskType
  priority    Priority

  @@map("tasks")
}

model LeadRoulette {
  id                String             @id @default(uuid())
  name              String
  isActive          Boolean            @default(true)
  validFrom         DateTime?
  validUntil        DateTime?
  lastAssignedIndex Int                @default(0)
  users             LeadRouletteUser[]
  funnelId          String?
  funnel            Funnel?            @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  @@map("lead_roulettes")
}

model LeadRouletteUser {
  rouletteId String
  roulette   LeadRoulette @relation(fields: [rouletteId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([rouletteId, userId])
  @@map("roulette_users")
}

model Funnel {
  id             String             @id @default(uuid())
  name           String             @unique
  isPreSales     Boolean            @default(false)
  isDefaultEntry Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  stages         FunnelStage[]
  userAccess     UserFunnelAccess[]
  clients        Client[]
  roulettes      LeadRoulette[]

  @@map("funnels")
}

model FunnelStage {
  id        String   @id @default(uuid())
  name      String
  order     Int
  color     String
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]

  @@unique([funnelId, name])
  @@map("funnel_stages")
}

model UserFunnelAccess {
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  funnelId    String
  funnel      Funnel            @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  accessLevel FunnelAccessLevel

  @@id([userId, funnelId])
  @@map("user_funnel_access")
}

model ActiveOffer {
  id          String              @id @default(uuid())
  name        String
  status      ActiveOfferStatus   @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdById String
  createdBy   User                @relation("CreatedOffers", fields: [createdById], references: [id])
  clients     ActiveOfferClient[]

  @@map("active_offers")
}

model ActiveOfferClient {
  id            String                  @id @default(uuid())
  status        ActiveOfferClientStatus @default(PENDING)
  notes         String?
  contactedAt   DateTime?
  activeOfferId String
  activeOffer   ActiveOffer             @relation(fields: [activeOfferId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedToId  String
  assignedTo    User                    @relation("AssignedCalls", fields: [assignedToId], references: [id])

  @@map("active_offer_clients")
}

model AttendanceConfig {
  id           String             @id @default(cuid())
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Int
  schedules    Json
  weekDays     Int[]              @default([])
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  records      AttendanceRecord[]

  @@map("attendance_configs")
}

model AttendanceRecord {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  latitude           Float
  longitude          Float
  distanceFromCenter Int
  isWithinRadius     Boolean
  configId           String?
  config             AttendanceConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())

  @@map("attendance_records")
}

model LeadPoolConfig {
  id                        String   @id @default(cuid())
  assignmentRadiusMeters    Int      @default(5000)
  timeToPriorityPoolMinutes Int      @default(60)
  timeToGeneralPoolMinutes  Int      @default(120)
  updatedAt                 DateTime @updatedAt

  @@map("lead_pool_configs")
}

model LeadPool {
  id       String         @id @default(cuid())
  name     String         @unique
  isActive Boolean        @default(true)
  users    LeadPoolUser[]

  @@map("lead_pools")
}

model LeadPoolUser {
  leadPoolId String
  leadPool   LeadPool @relation(fields: [leadPoolId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leadPoolId, userId])
  @@map("lead_pool_users")
}

model ClientWonDetails {
  id        String   @id @default(uuid())
  saleValue Float
  saleDate  DateTime @default(now())
  createdAt DateTime @default(now())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_won_details")
}

model LostReason {
  id        String   @id @default(uuid())
  reason    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("lost_reasons")
}

model RoleSetting {
  roleName Role    @id
  isActive Boolean @default(true)

  @@map("role_settings")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model FieldMapping {
  id          String   @id @default(uuid())
  source      String // ex: "meta_ads", "site_form"
  fieldName   String // Nome do campo na fonte (ex: "full_name")
  mappedField String // Nome do campo no modelo Client (ex: "fullName")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, fieldName])
  @@map("field_mappings")
}